# ═══════════════════════════════════════════════
# BTC Predictor v2 — Configuración
# ═══════════════════════════════════════════════

# DeepSeek API Key (https://platform.deepseek.com)
# 5 millones de tokens gratis al registrarte
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Web3 Execution (optional — absent = offline_sim mode) ──
# TRADING_MODE: offline_sim (default) | live_mainnet
TRADING_MODE=live_mainnet

# Polymarket native L2 CLOB — py-clob-client integration.
# See https://github.com/Polymarket/py-clob-client

# L2 signing key (hex 0x...). For delegated Google/Email wallets this is
# the EOA signing key exported from Polymarket's "Export private key"
# dialog — NOT the on-chain Safe/Proxy address.
WALLET_PRIVATE_KEY=
# Legacy alias — kept for backward compat.
ETH_PRIVATE_KEY=

# Polymarket Proxy/Funder wallet — the PUBLIC 0x... address shown in the
# Polymarket UI (the Safe/Proxy that holds USDC.e). Required because the
# bot uses signature_type=1 (delegated web wallet flow).
POLYMARKET_PROXY_FUNDER=
# Legacy alias — kept for backward compat.
POLYMARKET_FUNDER_ADDRESS=

# Hour (UTC) for automatic gasless redeem cron (default: 3)
REDEEM_CRON_HOUR_UTC=3

# Prometheus metrics exporter (optional)
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9108
